# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Path to your Firebase service account JSON key.
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/serviceAccountKey.json

# Firebase Auth UID of the account that owns all the data.
# Get it from: Firebase Console → Authentication → Users → copy the User UID column
USER_ID=your-firebase-uid-here
